<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- ================= New Vaccine ================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="New Vaccine"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name" />

        <Spinner
            android:id="@+id/spinnerVaccineName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/white_input_bg"
            android:spinnerMode="dialog" />

        <!-- Dose -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dose" />

        <Spinner
            android:id="@+id/spinnerDose"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/white_input_bg" />

        <!-- Date & Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:text="Date">

                </TextView>

                <EditText
                    android:id="@+id/edtVaccineDate"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@drawable/white_input_bg"
                    android:focusable="false"
                    android:hint="29/03/2025"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnVaccineDatePicker"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="10dp"
                    android:background="@drawable/brown_bg"
                    android:padding="2dp"
                    android:src="@drawable/calendar_icon"
                    app:tint="@color/light_brown">

                </ImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time">

                </TextView>

                <EditText
                    android:id="@+id/edtVaccineTime"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/white_input_bg"
                    android:focusable="false"
                    android:hint="10:00 a.m."
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnVaccineTimePicker"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/brown_bg"
                    android:padding="2dp"
                    android:src="@drawable/clock_icon"
                    app:tint="@color/light_brown">

                </ImageView>
            </LinearLayout>
        </LinearLayout>
        <!-- Place -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Place" />

        <EditText
            android:id="@+id/edtVaccinePlace"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/white_input_bg"
            android:hint="Vet Hospital" />

        <!-- ================= Next Vaccine Button ================= -->
        <LinearLayout
            android:id="@+id/btnNextVaccine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/brown_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Next Vaccine"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_add"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- ================= Next Vaccine Form (Hidden) ================= -->
        <LinearLayout
            android:id="@+id/layoutNextVaccine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:background="@drawable/light_brown_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:translationZ="-1dp"

            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Name" />

            <Spinner
                android:id="@+id/spinnerNextVaccineName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/white_input_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Dose" />

            <Spinner
                android:id="@+id/spinnerNextDose"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/white_input_bg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">


                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:text="Date">

                    </TextView>

                    <EditText
                        android:id="@+id/edtNextVaccineDate"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:background="@drawable/white_input_bg"
                        android:focusable="false"
                        android:hint="29/03/2025"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/btnNextVaccineDatePicker"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_margin="10dp"
                        android:background="@drawable/brown_bg"
                        android:padding="2dp"
                        android:src="@drawable/calendar_icon"
                        app:tint="@color/light_brown">

                    </ImageView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time">

                    </TextView>

                    <EditText
                        android:id="@+id/edtNextVaccineTime"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/white_input_bg"
                        android:focusable="false"
                        android:hint="10:00 a.m."
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/btnNextVaccineTimePicker"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/brown_bg"
                        android:padding="2dp"
                        android:src="@drawable/clock_icon"
                        app:tint="@color/light_brown">

                    </ImageView>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Place" />

            <EditText
                android:id="@+id/edtNextVaccinePlace"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/white_input_bg"
                android:hint="Vet Hospital" />

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>